
# .env.example — modelo de variáveis de ambiente do FieldEye
# Copie para .env e ajuste. O .env real NÃO vai para o git (ver .gitignore).
# Em Docker Compose, os serviços se enxergam pelo NOME do serviço (ex.: o
# host do banco é "postgres", o do redis é "redis") — não use "localhost".


# Banco de dados (PostgreSQL) 
POSTGRES_USER=fieldeye
POSTGRES_PASSWORD=troque_esta_senha_no_env_real
POSTGRES_DB=fieldeye
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# URL síncrona (usada por scripts/migrações simples)
DATABASE_URL=postgresql://fieldeye:troque_esta_senha_no_env_real@postgres:5432/fieldeye
# URL assíncrona (usada pelo FastAPI + SQLAlchemy async / asyncpg)
DATABASE_URL_ASYNC=postgresql+asyncpg://fieldeye:troque_esta_senha_no_env_real@postgres:5432/fieldeye

#  Fila / cache (Redis) 
# O Celery (worker) usa o Redis como "broker" (fila) e backend de resultados.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

#  Autenticação (JWT) 
# JWT_SECRET assina os tokens. Em produção, use uma chave longa e aleatória.
JWT_SECRET=troque_por_uma_chave_secreta_bem_longa_e_aleatoria
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 horas
REFRESH_TOKEN_EXPIRE_DAYS=7        # 7 dias

#  Caminhos de dados 
# HOST_DATA_DIR = pasta NO HOST onde os vídeos ficam guardados. Deixe vazio
# para usar ./data (dentro do projeto) ou aponte para fora (ex.: D:/fieldeye-data
# no Windows, /var/fieldeye-data no Linux) para não misturar com o repositório.
# HOST_DATA_DIR=./data
# Os caminhos abaixo são DENTRO do contêiner (não precisam mudar).
DATA_DIR=/data
UPLOADS_DIR=/data/uploads
OUTPUTS_DIR=/data/outputs
MODELS_DIR=/data/models

#  Docker Compose 
# Descomente para habilitar a GPU NVIDIA (CUDA) automaticamente no worker.
# Só funciona em máquinas com GPU NVIDIA + drivers. Em Windows use ";" como
# separador; em Linux/macOS use ":".
# COMPOSE_FILE=docker-compose.yml;docker-compose.gpu.yml

#  Frontend
# URL pública da API (passa pelo gateway Traefik na porta 80).
NEXT_PUBLIC_API_URL=http://localhost


# Ajustes do worker / pipeline de IA (todos opcionais — têm padrão no código)

# Modo "Velocidade" (rápido, roda em qualquer CPU):
MODEL_NAME=yolov8n.pt
YOLO_IMGSZ=0          # 0 = padrão 640
YOLO_CONF=0.3         # confiança mínima (0.0–1.0)

# Modo "Qualidade" (detecta jogadores pequenos/distantes; pesado, ideal com GPU):
MODEL_NAME_HQ=yolov8s.pt
YOLO_IMGSZ_HQ=1280
YOLO_CONF_HQ=0.2

# Consolidação de IDs (fragmentos -> jogadores reais)
CONS_MAX_GAP=45
CONS_MAX_DIST=5.0
CONS_MIN_FRAMES=15
CONS_MIN_DIST=2.0
