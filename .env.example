# ===================================================================
# .env.example — modelo de variáveis de ambiente do FieldEye
# Copie para .env e ajuste. O .env real NÃO vai para o git (ver .gitignore).
# As variáveis de infraestrutura (banco, redis, JWT) entram na Fase 6.
# ===================================================================

# --- Ajustes do worker / pipeline de IA ---

# Modelo YOLO. Padrão leve (rápido em CPU). Para câmera tática aberta
# (jogadores pequenos), use um modelo maior, ex.: yolov8x.pt
MODEL_NAME=yolov8n.pt

# Resolução de inferência do YOLO. 0 = padrão do modelo (640).
# Para jogadores pequenos (vista aérea), aumente para 1920 ou 2560.
# ATENÇÃO: valores altos deixam a detecção MUITO mais lenta (ideal com GPU).
YOLO_IMGSZ=0

# Confiança mínima de detecção (0.0 a 1.0). Baixe (ex.: 0.10) para captar
# jogadores pequenos/borrados; suba para reduzir falsos positivos.
YOLO_CONF=0.3

# --- Consolidação de IDs (transforma fragmentos em jogadores reais) ---

# Gap temporal máximo (frames) para costurar dois fragmentos sequenciais.
CONS_MAX_GAP=45
# Distância máxima (metros) entre fim de um fragmento e início do próximo.
CONS_MAX_DIST=5.0
# Filtro de ruído: nº mínimo de frames para um track contar como jogador.
CONS_MIN_FRAMES=15
# Filtro de ruído: distância mínima (metros) percorrida.
CONS_MIN_DIST=2.0
